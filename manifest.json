{
  "manifest_version": 3,
  "name": "Clear Cache & Hard Reload",
  "version": "1.0.0",
  "description": "Click to clear the cache and hard-reload the current tab.",
  "author": "Isaias Garcia",
  "homepage_url": "https://github.com/isaiasgv/ClearCache",
  "minimum_chrome_version": "102",
  "permissions": [
    "browsingData",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Clear cache & hard reload",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
